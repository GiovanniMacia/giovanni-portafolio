---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="flex flex-col bg-slate-900 text-white">

    <!-- HERO -->
    <section id="home" class="min-h-screen flex items-center justify-center pt-20 ...">
      <div class="text-center max-w-3xl mx-4">

        <p class="text-orange-400 font-medium mb-3 tracking-wider">
          👋 Hola, soy
        </p>

        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight">
          Giovanni Macia
        </h1>

        <p class="text-slate-300 text-lg md:text-xl mb-10 max-w-xl mx-auto">
          Desarrollador Frontend enfocado en crear interfaces modernas, rápidas y funcionales.
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <a href="#projects"
            class="bg-orange-500 hover:bg-orange-600 text-white font-semibold py-3 px-7 rounded-full transition-all duration-300 transform hover:scale-105 shadow-lg">
            Ver proyectos
          </a>

          <a href="/CV-Giovanni-Macia.pdf"
            class="border border-slate-600 hover:border-orange-400 text-white font-semibold py-3 px-7 rounded-full transition-all duration-300 hover:bg-slate-800">
            Descargar CV
          </a>
        </div>

      </div>
    </section>

    <!-- SOBRE MI -->
    <section id="about" class="fade-in py-24 px-6">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12 items-center">

        <div class="flex justify-center">
          <img src="/tu-foto.jpg" alt="Giovanni Macia"
            class="w-60 h-60 object-cover rounded-2xl border border-slate-700 shadow-lg">
        </div>

        <div>
          <h2 class="text-3xl font-bold mb-6">Sobre mí</h2>

          <p class="text-slate-300 text-lg leading-relaxed mb-4">
            Soy desarrollador frontend en formación, enfocado en crear interfaces claras y funcionales.
          </p>

          <p class="text-slate-400">
            Actualmente estudio Analista de Sistemas y trabajo con tecnologías como Astro y Tailwind CSS.
            Busco mi primera experiencia profesional para seguir creciendo y aportar en proyectos reales.
          </p>
        </div>

      </div>
    </section>

    <!-- TECNOLOGIAS -->
    <section id="skills" class="fade-in py-20 bg-slate-900/50" style="transition-delay: 0.1s;">
      <div class="max-w-5xl mx-auto text-center">

        <h2 class="text-3xl font-bold mb-12">Tecnologías</h2>

        <div class="flex flex-wrap justify-center gap-6">

          <div class="bg-slate-800 px-6 py-3 rounded-xl border border-slate-700 hover:border-orange-400 transition">HTML</div>
          <div class="bg-slate-800 px-6 py-3 rounded-xl border border-slate-700 hover:border-orange-400 transition">CSS</div>
          <div class="bg-slate-800 px-6 py-3 rounded-xl border border-slate-700 hover:border-orange-400 transition">JavaScript</div>
          <div class="bg-slate-800 px-6 py-3 rounded-xl border border-slate-700 hover:border-orange-400 transition">Astro</div>
          <div class="bg-slate-800 px-6 py-3 rounded-xl border border-slate-700 hover:border-orange-400 transition">Tailwind</div>

        </div>

      </div>
    </section>

    <!-- PROYECTOS -->
   <section id="projects" class="fade-in py-20 px-6" style="transition-delay: 0.2s;">
      <div class="max-w-5xl mx-auto">

        <h2 class="text-3xl font-bold mb-12 text-center">Proyectos</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

          <div class="group bg-slate-800 border border-slate-700 rounded-xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-orange-400">

            <img src="/proyecto1.png" alt="Proyecto" class="w-full h-40 object-cover">

            <div class="p-6">
              <h3 class="text-xl font-bold mb-2">Mi Primer Portafolio</h3>

              <p class="text-slate-400 mb-4">
                Sitio desarrollado con Astro y Tailwind enfocado en rendimiento y diseño moderno.
              </p>

              <div class="flex gap-3 text-sm mb-4">
                <span class="text-orange-400">Astro</span>
                <span class="text-orange-400">Tailwind</span>
              </div>

              <div class="flex gap-4">
                <a href="#" class="text-orange-400 hover:underline font-semibold">Ver Demo</a>
                <a href="#" class="text-slate-400 hover:text-white">GitHub</a>
              </div>
            </div>

          </div>

        </div>

      </div>
    </section>

    <!-- CONTACTO -->
    <section id="contact" class="fade-in py-20 text-center px-6" style="transition-delay: 0.2s;">
      <h2 class="text-3xl font-bold mb-6">¿Hablamos?</h2>

      <p class="text-slate-400 mb-8">
        ¿Tenés una oportunidad o proyecto? Estoy abierto a colaborar.
      </p>

      <a href="https://wa.me/5493525419426"
        target="_blank"
        class="inline-block px-8 py-3 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-full transition-all duration-300 transform hover:scale-105 shadow-lg">
        Enviar WhatsApp
      </a>

      <div class="mt-10 flex justify-center gap-8">

        <a href="mailto:maciagiovanni4@gmail.com" class="text-slate-400 hover:text-orange-400 transition">
          Email
        </a>

        <a href="https://www.linkedin.com/in/giovanni-macia-632a2b359" target="_blank"
          class="text-slate-400 hover:text-orange-400 transition">
          LinkedIn
        </a>

      </div>
    </section>

  </main>
</Layout>
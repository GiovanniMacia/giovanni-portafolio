---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="flex flex-col bg-slate-900 text-white">

    <section id="home" class="min-h-screen flex items-center justify-center pt-20">
      <div class="text-center max-w-3xl mx-4 hero-animate">
        <h1 class="text-4xl md:text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-rose-400 mb-4">
          Hola, soy Giovanni 👋
        </h1>

        <p class="text-slate-300 text-lg mb-8">
          Estudiante de <strong>Analista de Sistemas</strong> enfocado en crear interfaces modernas, eficientes y soluciones tecnológicas de alto impacto.
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <a href="https://www.linkedin.com/in/giovanni-macia-632a2b359" target="_blank" class="bg-[#0077b5] hover:bg-[#005c8d] text-white font-semibold py-3 px-6 rounded-full transition-all hover:scale-105 flex items-center gap-2">
             LinkedIn
          </a>
          <a href="/CV-Giovanni-Macia-Sistemas.pdf" download class="bg-slate-700 hover:bg-slate-600 text-white font-semibold py-3 px-6 rounded-full transition-all hover:scale-105 flex items-center gap-2 border border-slate-500">
             Descargar CV
          </a>
          <a href="https://github.com/GiovanniMacia" target="_blank" class="bg-slate-800 hover:bg-black text-white font-semibold py-3 px-6 rounded-full transition-all hover:scale-105">
             GitHub
          </a>
        </div>
      </div>
    </section>

    <section id="about" class="fade-in py-24 px-6">
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-12 items-center">
        <div class="text-left">
          <h2 class="fade-item text-3xl font-bold mb-6 border-l-4 border-orange-400 pl-4">Sobre mí</h2>
          <p class="fade-item text-slate-300 text-lg mb-4">
            Soy un apasionado de la tecnología de 20 años, actualmente cursando la carrera de <strong>Analista de Sistemas</strong> en el Colegio Universitario IES.
          </p>
          <p class="fade-item text-slate-400 mb-6">
            Mi experiencia previa como Asistente Administrativo en <strong>7B ingeniería</strong> me brindó habilidades de organización y responsabilidad, las cuales aplico hoy en el desarrollo de software. Me destaco por mi pensamiento analítico y mi rapidez para aprender nuevas herramientas.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-4">
          <div class="fade-item bg-slate-800/50 p-4 rounded-lg border border-slate-700">
            <h4 class="font-bold text-orange-400 mb-1 text-sm uppercase tracking-widest">Educación Principal</h4>
            <p class="text-white font-medium">Analista de Sistemas</p>
            <p class="text-slate-500 text-xs">Colegio Universitario IES (En curso)</p>
          </div>
          <div class="fade-item bg-slate-800/50 p-4 rounded-lg border border-slate-700">
            <h4 class="font-bold text-orange-400 mb-1 text-sm uppercase tracking-widest">Certificaciones</h4>
            <p class="text-white font-medium">Bases de Datos e Introducción a la Programación</p>
            <p class="text-slate-500 text-xs">UTN Córdoba (2023)</p>
          </div>
        </div>
      </div>
    </section>

    <section id="skills" class="fade-in py-24 px-6 bg-slate-900/50">
      <div class="max-w-6xl mx-auto text-center">
        <h2 class="fade-item text-3xl md:text-4xl font-bold mb-12">Tecnologías</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-6">
          <div class="fade-item group bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-orange-400 transition-all hover:-translate-y-2">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg" class="w-12 h-12 mb-4 mx-auto" />
            <h3 class="font-semibold text-orange-400">HTML</h3>
          </div>
          <div class="fade-item group bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-blue-400 transition-all hover:-translate-y-2">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg" class="w-12 h-12 mb-4 mx-auto" />
            <h3 class="font-semibold text-blue-400">CSS</h3>
          </div>
          <div class="fade-item group bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-yellow-400 transition-all hover:-translate-y-2">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg" class="w-12 h-12 mb-4 mx-auto" />
            <h3 class="font-semibold text-yellow-400">JavaScript</h3>
          </div>
          <div class="fade-item group bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-purple-400 transition-all hover:-translate-y-2">
            <img src="https://api.iconify.design/logos:astro.svg" class="w-12 h-12 mb-4 mx-auto" />
            <h3 class="font-semibold text-purple-400">Astro</h3>
          </div>
          <div class="fade-item group bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-cyan-400 transition-all hover:-translate-y-2">
            <img src="https://www.vectorlogo.zone/logos/tailwindcss/tailwindcss-icon.svg" class="w-12 h-12 mb-4 mx-auto" />
            <h3 class="font-semibold text-cyan-400">Tailwind</h3>
          </div>
        </div>
      </div>
    </section>

    <section id="projects" class="fade-in py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="fade-item text-3xl md:text-4xl font-bold text-center mb-12">Proyectos</h2>
        <div class="grid md:grid-cols-2 gap-8">
          
          <div class="fade-item group bg-slate-800 rounded-xl overflow-hidden border border-slate-700 hover:border-cyan-400 transition-all hover:-translate-y-2 shadow-lg">
            <div class="h-48 bg-white/5 flex items-center justify-center p-8">
              <img src="/soltec-logo.png" class="max-h-full object-contain" alt="Soltec Logo" />
            </div>
            <div class="p-6">
              <div class="flex justify-between items-start mb-2">
                <h3 class="text-xl font-bold text-white">Soltec</h3>
                <span class="text-[10px] uppercase bg-cyan-500/10 text-cyan-400 px-2 py-1 rounded border border-cyan-500/20">En Desarrollo</span>
              </div>
              <p class="text-slate-400 text-sm mb-4">Proyecto colaborativo para brindar soluciones tecnológicas integrales. Liderando la interfaz web.</p>
            </div>
          </div>

          <div class="fade-item group bg-slate-800 rounded-xl overflow-hidden border border-slate-700 hover:border-orange-400 transition-all hover:-translate-y-2 shadow-lg">
            <div class="h-48 bg-slate-700 flex items-center justify-center italic text-slate-500">
               [ Vista Previa Portafolio ]
            </div>
            <div class="p-6">
              <div class="flex justify-between items-start mb-2">
                <h3 class="text-xl font-bold text-white">Mi Portafolio</h3>
                <span class="text-[10px] uppercase bg-green-500/10 text-green-400 px-2 py-1 rounded border border-green-500/20">Completado</span>
              </div>
              <p class="text-slate-400 text-sm mb-4">Landing page optimizada desarrollada con Astro y Tailwind CSS.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section id="contact" class="fade-in py-24 text-center px-6">
      <h2 class="fade-item text-3xl font-bold mb-6">¿Hablamos?</h2>
      <a href="https://wa.me/5493525419426" target="_blank" class="fade-item inline-block px-10 py-4 bg-green-600 hover:bg-green-700 text-white font-bold rounded-full transition-transform hover:scale-105 shadow-xl">
        Enviar WhatsApp
      </a>
      
      <div class="fade-item mt-12 flex justify-center gap-8">
        <a href="mailto:maciagiovanni4@gmail.com" class="text-slate-400 hover:text-orange-400 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        </a>
        <a href="https://www.linkedin.com/in/giovanni-macia-632a2b359" target="_blank" class="text-slate-400 hover:text-[#0077b5] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
      </div>
    </section>

    <footer class="py-10 text-center text-slate-500 text-sm border-t border-slate-800">
      <p>© 2024 Giovanni Macia Godoy | Jesús María, Córdoba</p>
      <p class="mt-2 text-xs opacity-50 font-mono">Hecho con Astro + Tailwind</p>
    </footer>

  </main>
</Layout>
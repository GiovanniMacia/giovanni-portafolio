---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="flex flex-col bg-slate-900">
    
    <section id="home" class="min-h-screen flex items-center justify-center pt-20">
      <div class="text-center p-10 bg-slate-800 rounded-2xl shadow-2xl border border-slate-700 max-w-3xl mx-4">
        <h1 class="text-4xl md:text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-rose-400 mb-4">
          ¡Giovanni Macia!
        </h1>
        <p class="text-slate-300 text-lg mb-8">
          Estudiante de Analista de Sistemas | Frontend Developer
        </p>
        
        <div class="flex flex-wrap justify-center gap-4">
          <a href="https://www.linkedin.com/in/giovanni-macia-632a2b359" target="_blank" class="bg-[#0077b5] hover:bg-[#005c8d] text-white font-bold py-3 px-6 rounded-full transition-all transform hover:scale-105 flex items-center gap-2 shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            LinkedIn
          </a>

          <a href="/CV-Giovanni-Macia.pdf" download class="bg-slate-700 hover:bg-slate-600 text-white font-bold py-3 px-6 rounded-full transition-all transform hover:scale-105 border border-slate-500 flex items-center gap-2 shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            Descargar CV
          </a>

          <a href="https://github.com/GiovanniMacia" target="_blank" class="bg-slate-900 hover:bg-black text-white font-bold py-3 px-6 rounded-full transition-all transform hover:scale-105 border border-slate-700 flex items-center gap-2 shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C4.8 1.5 3.7 1.8 3.7 1.8a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 2.3 8.2c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21"></path></svg>
            GitHub
          </a>
        </div>
      </div>
    </section>

    <section id="about" class="min-h-[60vh] flex flex-col items-center justify-center px-6 py-20">
      <div class="max-w-2xl text-center">
        <h2 class="text-3xl font-bold text-white mb-6">Sobre mí</h2>
        <p class="text-slate-200 text-lg leading-relaxed">
          Soy estudiante de 20 años de la carrera <strong>Analista de Sistemas</strong> en el Colegio Universitario IES[cite: 5, 15]. 
          Me destaco por mi capacidad de aprendizaje rápido y predisposición para el trabajo en equipo[cite: 6]. 
          Actualmente enfocado en dominar tecnologías como <strong>Astro</strong> y <strong>Tailwind CSS</strong> para contribuir con soluciones efectivas en el ámbito IT[cite: 6].
        </p>
      </div>
    </section>

    <section id="projects" class="min-h-screen bg-slate-900/50 py-20 px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-white mb-12 text-center">Mis Proyectos</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="group bg-slate-800 border border-slate-700 p-6 rounded-xl hover:border-orange-500 transition-all hover:-translate-y-2 hover:shadow-2xl hover:shadow-orange-500/10">
            <div class="h-40 bg-slate-700 rounded-lg mb-4 flex items-center justify-center text-slate-500 font-mono italic">
              [Imagen del Proyecto]
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Mi Primer Portafolio</h3>
            <p class="text-slate-400 mb-4">Sitio estático creado con Astro y Tailwind centrado en la velocidad y el diseño minimalista.</p>
            <div class="flex gap-4">
              <a href="#" class="text-orange-400 hover:underline font-semibold">Ver Demo</a>
              <a href="https://github.com/GiovanniMacia/giovanni-portafolio" target="_blank" class="text-slate-500 hover:text-white">GitHub</a>
            </div>
          </div>

          <div class="group bg-slate-800 border border-slate-700 p-6 rounded-xl hover:border-blue-500 transition-all">
            <div class="h-40 bg-slate-700 rounded-lg mb-4 flex items-center justify-center text-slate-500 font-mono italic">
              [Imagen del Proyecto]
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Próximamente</h3>
            <p class="text-slate-400 mb-4">Aquí aparecerá tu siguiente gran aplicación web.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="contact" class="py-20 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">¿Hablamos?</h2>
      <p class="text-slate-400 mb-8">Estoy abierto a nuevas oportunidades y colaboraciones.</p>
      
      <a href="https://wa.me/5493525419426?text=Hola%20Giovanni,%20vi%20tu%20portafolio..." 
         target="_blank" 
         class="inline-block px-8 py-3 bg-green-600 hover:bg-green-700 text-white font-bold rounded-full transition-all shadow-lg transform hover:scale-105">
        Enviar WhatsApp
      </a>

      <div class="mt-10 flex justify-center gap-8">
        <a href="mailto:maciagiovanni4@gmail.com" class="text-slate-400 hover:text-orange-400 transition-colors" title="Enviame un mail">
          <svg xmlns="http://www.w3.org/2000/svg" width="35" height="35" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/giovanni-macia-632a2b359" target="_blank" class="text-slate-400 hover:text-[#0077b5] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="35" height="35" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
      </div>
    </section>

  </main>
</Layout>
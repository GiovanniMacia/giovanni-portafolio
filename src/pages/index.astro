---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <nav class="fixed w-full z-50 bg-slate-900/80 backdrop-blur-md border-b border-slate-800 px-6 py-4">
    <div class="max-w-6xl mx-auto flex justify-between items-center">
      <a href="#home" class="flex items-center gap-2 group">
        <img src="https://api.iconify.design/lucide:gradient-circle.svg" class="w-8 h-8 group-hover:rotate-180 transition-transform duration-500" alt="Logo G" />
        <span class="font-bold text-xl tracking-tighter">GIOVANNI</span>
      </a>
      
      <button id="menu-btn" class="md:hidden text-white focus:outline-none">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>

      <div class="hidden md:flex gap-8 font-medium text-sm text-slate-400">
        <a href="#about" class="hover:text-orange-400 transition-colors">Sobre mí</a>
        <a href="#skills" class="hover:text-orange-400 transition-colors">Stack</a>
        <a href="#projects" class="hover:text-orange-400 transition-colors">Proyectos</a>
        <a href="#contact" class="hover:text-orange-400 transition-colors text-white border border-slate-700 px-4 py-1 rounded-full hover:bg-slate-800">Contacto</a>
      </div>
    </div>

    <div id="mobile-menu" class="hidden flex-col gap-4 pt-6 pb-4 md:hidden text-center border-t border-slate-800 mt-4">
      <a href="#about" class="block py-2 text-slate-300">Sobre mí</a>
      <a href="#skills" class="block py-2 text-slate-300">Stack</a>
      <a href="#projects" class="block py-2 text-slate-300">Proyectos</a>
      <a href="#contact" class="block py-2 text-orange-400 font-bold">Contacto</a>
    </div>
  </nav>

  <main class="flex flex-col bg-slate-900 text-white pt-20">

    <section id="home" class="min-h-[90vh] flex items-center justify-center">
      <div class="text-center max-w-3xl mx-4 hero-animate">
        <h1 class="text-5xl md:text-7xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-rose-400 mb-4">
          Giovanni Macia
        </h1>
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">
          Frontend Developer en formación
        </h2>
        <p class="text-slate-300 text-lg mb-8 max-w-2xl mx-auto leading-relaxed">
          Construyo interfaces modernas, rápidas y enfocadas en el usuario. Estudiante de Analista de Sistemas con base técnica en lógica y bases de datos.
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <a href="https://www.linkedin.com/in/giovanni-macia-632a2b359" target="_blank" class="bg-[#0077b5] hover:bg-[#005c8d] text-white font-semibold py-3 px-8 rounded-full transition-all hover:scale-105 flex items-center gap-2 shadow-lg">LinkedIn</a>
          <a href="/CV-Giovanni-Macia-Sistemas.pdf" download class="bg-slate-800 hover:bg-slate-700 text-white font-semibold py-3 px-8 rounded-full transition-all hover:scale-105 border border-slate-700 shadow-lg">Descargar CV</a>
        </div>
      </div>
    </section>

    <section id="about" class="py-24 px-6">
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-12 items-center">
        <div class="text-left">
          <h2 class="text-3xl font-bold mb-6 border-l-4 border-orange-400 pl-4 uppercase tracking-tighter">Sobre mí</h2>
          <p class="text-slate-300 text-lg mb-4 leading-relaxed">
            Actualmente estoy enfocado en mejorar mis habilidades en JavaScript y construir proyectos prácticos que simulen entornos reales de trabajo.
          </p>
          <p class="text-slate-400 leading-relaxed">
            Mi formación en el <strong>IES</strong> y la <strong>UTN</strong>, junto a mi experiencia en <strong>7B ingeniería</strong>, me otorga un perfil analítico y organizado para el desarrollo de software profesional.
          </p>
        </div>
        <div class="space-y-4">
          <div class="bg-slate-800/50 p-5 rounded-2xl border border-slate-700/50 backdrop-blur-sm">
            <h4 class="font-bold text-orange-400 mb-1 text-xs uppercase tracking-widest">Educación</h4>
            <p class="text-white font-medium">Analista de Sistemas - IES (En curso)</p>
          </div>
          <div class="bg-slate-800/50 p-5 rounded-2xl border border-slate-700/50 backdrop-blur-sm">
            <h4 class="font-bold text-orange-400 mb-1 text-xs uppercase tracking-widest">Certificaciones</h4>
            <p class="text-white font-medium text-sm">Bases de Datos & Programación - UTN</p>
          </div>
        </div>
      </div>
    </section>

    <section id="skills" class="py-24 px-6 bg-slate-900/50 text-center">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold mb-12">🧩 Stack Tecnológico</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
          <div class="bg-slate-800/30 p-8 rounded-3xl border border-slate-800 hover:border-orange-500/50 transition-all">
            <h3 class="text-orange-400 font-bold mb-6 text-sm uppercase tracking-widest">Frontend</h3>
            <div class="flex flex-wrap justify-center gap-6">
              <img src="https://api.iconify.design/vscode-icons:file-type-html.svg" class="w-10 h-10" title="HTML5" />
              <img src="https://api.iconify.design/vscode-icons:file-type-css.svg" class="w-10 h-10" title="CSS3" />
              <img src="https://api.iconify.design/vscode-icons:file-type-js-official.svg" class="w-10 h-10" title="JavaScript" />
              <img src="https://api.iconify.design/logos:astro-icon.svg" class="w-10 h-10" title="Astro" />
              <img src="https://api.iconify.design/vscode-icons:file-type-tailwind.svg" class="w-10 h-10" title="Tailwind CSS" />
            </div>
            <p class="mt-4 text-[10px] text-slate-500 uppercase font-bold tracking-widest">Responsive Design</p>
          </div>
          <div class="bg-slate-800/30 p-8 rounded-3xl border border-slate-800 hover:border-blue-500/50 transition-all">
            <h3 class="text-blue-400 font-bold mb-6 text-sm uppercase tracking-widest">Backend & Bases</h3>
            <div class="flex justify-center gap-6">
              <img src="https://api.iconify.design/logos:nodejs-icon.svg" class="w-10 h-10" />
              <img src="https://api.iconify.design/logos:express.svg" class="w-10 h-10 bg-white rounded p-1" />
              <img src="https://api.iconify.design/vscode-icons:file-type-sql.svg" class="w-10 h-10" />
            </div>
          </div>
          <div class="bg-slate-800/30 p-8 rounded-3xl border border-slate-800 hover:border-purple-500/50 transition-all">
            <h3 class="text-purple-400 font-bold mb-6 text-sm uppercase tracking-widest">Herramientas</h3>
            <div class="flex justify-center gap-6">
              <img src="https://api.iconify.design/vscode-icons:file-type-git.svg" class="w-10 h-10" />
              <img src="https://api.iconify.design/hugeicons:github.svg" class="w-10 h-10 text-white" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="projects" class="py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl md:text-5xl font-bold text-center mb-16 tracking-tighter">Proyectos Destacados</h2>
        <div class="grid md:grid-cols-2 gap-10">
          
          <div class="group bg-slate-800 rounded-3xl overflow-hidden border border-slate-700 hover:border-orange-400 transition-all shadow-2xl">
            <div class="h-64 w-full overflow-hidden bg-slate-700">
              <img src="/hupes-srl.png" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="Hupes SRL" />
            </div>
            <div class="p-8">
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-2xl font-bold text-white tracking-tighter uppercase italic">Hupes SRL</h3>
                <span class="text-[10px] font-bold bg-orange-500/20 text-orange-400 px-3 py-1 rounded-full border border-orange-500/30">TESIS</span>
              </div>
              <p class="text-slate-400 mb-6 leading-relaxed">Sistema web integral de gestión operativa y recursos para Pyme de máquinas viales.</p>
              <div class="flex gap-4 pt-4 border-t border-slate-700/50 opacity-60">
                <img src="https://api.iconify.design/vscode-icons:file-type-html.svg" class="w-6 h-6" />
                <img src="https://api.iconify.design/vscode-icons:file-type-css.svg" class="w-6 h-6" />
                <img src="https://api.iconify.design/vscode-icons:file-type-js-official.svg" class="w-6 h-6" />
                <img src="https://api.iconify.design/logos:nodejs-icon.svg" class="w-6 h-6" />
              </div>
            </div>
          </div>

          <div class="group bg-slate-800 rounded-3xl overflow-hidden border border-slate-700 hover:border-cyan-400 transition-all shadow-2xl">
            <div class="h-64 w-full overflow-hidden bg-white/5">
              <img src="/soltec-logo.png" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="Soltec Logo" />
            </div>
            <div class="p-8">
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-2xl font-bold text-white tracking-tighter uppercase italic">Soltec</h3>
                <span class="text-[10px] font-bold bg-cyan-500/20 text-cyan-400 px-3 py-1 rounded-full border border-cyan-500/30">PROYECTO</span>
              </div>
              <p class="text-slate-400 mb-6 leading-relaxed">Proyecto colaborativo de hardware y soluciones tecnológicas para la comunidad local.</p>
              <div class="flex gap-4 pt-4 border-t border-slate-700/50 opacity-60">
                <img src="https://api.iconify.design/vscode-icons:file-type-html.svg" class="w-6 h-6" />
                <img src="https://api.iconify.design/vscode-icons:file-type-css.svg" class="w-6 h-6" />
                <img src="https://api.iconify.design/vscode-icons:file-type-js-official.svg" class="w-6 h-6" />
                <img src="https://api.iconify.design/logos:nodejs-icon.svg" class="w-6 h-6" />
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section id="contact" class="py-32 text-center px-6 bg-gradient-to-b from-slate-900 to-black">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 tracking-tighter">Disponible para oportunidades y proyectos freelance</h2>
      <p class="text-slate-400 mb-10 max-w-xl mx-auto">¿Tienes una idea? Hablemos y hagámosla realidad.</p>
      <a href="https://wa.me/5493525419426" target="_blank" class="inline-flex items-center gap-2 px-12 py-5 bg-green-600 hover:bg-green-500 text-white font-bold rounded-full transition-all hover:scale-105 shadow-[0_0_20px_rgba(34,197,94,0.3)]">
        Enviar WhatsApp
      </a>
    </section>

    <footer class="py-12 text-center text-slate-600 text-xs border-t border-slate-800/50">
      <p>© 2026 Giovanni Macia Godoy | Jesús María, Córdoba</p>
      <p class="mt-2 font-mono opacity-50 uppercase tracking-widest">Astro • Tailwind • Vercel</p>
    </footer>

  </main>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');

    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
      menu?.classList.toggle('flex');
    });

    // Cerrar menú al hacer click en un link
    const links = menu?.querySelectorAll('a');
    links?.forEach(link => {
      link.addEventListener('click', () => {
        menu?.classList.add('hidden');
        menu?.classList.remove('flex');
      });
    });
  </script>
</Layout>
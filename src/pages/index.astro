---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="flex flex-col bg-slate-900 text-white">

    <!-- HERO -->
    <section id="home" class="min-h-screen flex items-center justify-center pt-20">
      <div class="text-center max-w-3xl mx-4 hero-animate">

        <h1 class="text-4xl md:text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-rose-400 mb-4">
          Hola, soy Giovanni 👋
        </h1>

        <p class="text-slate-300 text-lg mb-8">
          Estudiante de Sistemas y desarrollador frontend en formación, enfocado en crear interfaces modernas y eficientes.
        </p>

        <div class="flex flex-wrap justify-center gap-4">

          <a href="https://www.linkedin.com/in/giovanni-macia-632a2b359"
             target="_blank"
             class="bg-[#0077b5] hover:bg-[#005c8d] text-white font-semibold py-3 px-6 rounded-full transition-all hover:scale-105">
            LinkedIn
          </a>

          <a href="C:\Users\macia\OneDrive\Documentos\Portafolio\portafolio\public\CV-Giovanni Macia Godoy (1).pdf"
             download
             class="bg-slate-700 hover:bg-slate-600 text-white font-semibold py-3 px-6 rounded-full transition-all hover:scale-105">
            Descargar CV
          </a>

          <a href="https://github.com/GiovanniMacia"
             target="_blank"
             class="bg-slate-800 hover:bg-black text-white font-semibold py-3 px-6 rounded-full transition-all hover:scale-105">
            GitHub
          </a>

        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="fade-in py-24 px-6 text-center">
      <div class="max-w-2xl mx-auto">

        <h2 class="fade-item text-3xl font-bold mb-6">Sobre mí</h2>

        <p class="fade-item text-slate-300 text-lg mb-4" style="transition-delay: 0.1s;">
          Soy estudiante de Analista de Sistemas con una fuerte motivación por el desarrollo frontend.
        </p>

        <p class="fade-item text-slate-400" style="transition-delay: 0.2s;">
          Me enfoco en crear interfaces modernas, rápidas y bien estructuradas utilizando tecnologías actuales.
        </p>

      </div>
    </section>

    <!-- TECNOLOGÍAS -->
    <section id="skills" class="fade-in py-24 px-6 bg-slate-900/50">
      <div class="max-w-6xl mx-auto text-center">

        <h2 class="fade-item text-3xl md:text-4xl font-bold mb-4">
          Tecnologías
        </h2>

        <p class="fade-item text-slate-400 mb-12" style="transition-delay: 0.1s;">
          Herramientas con las que construyo soluciones web modernas
        </p>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">

          <!-- HTML -->
          <div class="fade-item group relative bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-orange-400 transition-all hover:-translate-y-2 hover:shadow-xl" style="transition-delay: 0.1s;">
            <span class="absolute top-3 right-3 text-xs bg-orange-500/20 text-orange-400 px-2 py-1 rounded-full">Básico</span>
            <div class="flex justify-center mb-4">
              <svg class="w-10 h-10" viewBox="0 0 24 24" fill="#E34F26">
                <path d="M1.5 0h21l-1.9 21.6L12 24l-8.6-2.4L1.5 0z"/>
              </svg>
            </div>
            <h3>HTML</h3>
          </div>

          <!-- CSS -->
          <div class="fade-item group relative bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-blue-400 transition-all hover:-translate-y-2 hover:shadow-xl" style="transition-delay: 0.2s;">
            <span class="absolute top-3 right-3 text-xs bg-blue-500/20 text-blue-400 px-2 py-1 rounded-full">Básico</span>
            <div class="flex justify-center mb-4">
              <svg class="w-10 h-10" viewBox="0 0 24 24" fill="#1572B6">
                <path d="M1.5 0h21l-1.9 21.6L12 24l-8.6-2.4L1.5 0z"/>
              </svg>
            </div>
            <h3>CSS</h3>
          </div>

          <!-- JS -->
          <div class="fade-item group relative bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-yellow-400 transition-all hover:-translate-y-2 hover:shadow-xl" style="transition-delay: 0.3s;">
            <span class="absolute top-3 right-3 text-xs bg-yellow-500/20 text-yellow-400 px-2 py-1 rounded-full">Básico</span>
            <div class="flex justify-center mb-4">
              <svg class="w-10 h-10" viewBox="0 0 24 24" fill="#F7DF1E">
                <path d="M0 0h24v24H0z"/>
              </svg>
            </div>
            <h3>JavaScript</h3>
          </div>

          <!-- ASTRO -->
          <div class="fade-item group relative bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-purple-400 transition-all hover:-translate-y-2 hover:shadow-xl" style="transition-delay: 0.4s;">
            <span class="absolute top-3 right-3 text-xs bg-purple-500/20 text-purple-400 px-2 py-1 rounded-full">Aprendiendo</span>
            <div class="flex justify-center mb-4">
              <svg class="w-10 h-10" viewBox="0 0 24 24" fill="#BC52EE">
                <path d="M12 2C9 8 7 13 7 16c0 3 2 6 5 6s5-3 5-6c0-3-2-8-5-14z"/>
              </svg>
            </div>
            <h3>Astro</h3>
          </div>

          <!-- TAILWIND -->
          <div class="fade-item group relative bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-cyan-400 transition-all hover:-translate-y-2 hover:shadow-xl" style="transition-delay: 0.5s;">
            <span class="absolute top-3 right-3 text-xs bg-cyan-500/20 text-cyan-400 px-2 py-1 rounded-full">Intermedio</span>
            <div class="flex justify-center mb-4">
              <svg class="w-10 h-10" viewBox="0 0 24 24" fill="#38BDF8">
                <path d="M12 6c-2.7 0-4.5 1.3-5.5 4 1-.7 2-.9 3-.6"/>
              </svg>
            </div>
            <h3>Tailwind</h3>
          </div>

        </div>
      </div>
    </section>

    <!-- PROYECTOS -->
    <section id="projects" class="fade-in py-24 px-6">
      <div class="max-w-6xl mx-auto">

        <h2 class="fade-item text-3xl md:text-4xl font-bold text-center mb-4">
          Proyectos
        </h2>

        <div class="grid md:grid-cols-2 gap-8">

          <div class="fade-item group bg-slate-800 rounded-xl overflow-hidden border border-slate-700 hover:border-orange-400 transition-all hover:-translate-y-2 hover:shadow-xl">

            <img src="/proyecto1.png" class="w-full h-48 object-cover">

            <div class="p-6">
              <h3 class="text-xl font-bold mb-2">Mi Portafolio</h3>
              <p class="text-slate-400 mb-4">
                Portafolio personal desarrollado con Astro y Tailwind.
              </p>

              <div class="flex gap-4">
                <a href="#" class="text-orange-400">Ver Demo</a>
                <a href="https://github.com/GiovanniMacia" target="_blank" class="text-slate-400">GitHub</a>
              </div>
            </div>

          </div>

        </div>
      </div>
    </section>

    <!-- CONTACTO -->
    <section id="contact" class="fade-in py-20 text-center px-6">
      <h2 class="fade-item text-3xl font-bold mb-6">¿Hablamos?</h2>

      <a href="https://wa.me/5493525419426"
         target="_blank"
         class="fade-item inline-block px-8 py-3 bg-green-600 hover:bg-green-700 rounded-full transition"
         style="transition-delay: 0.2s;">
        Enviar WhatsApp
      </a>

      <div class="fade-item mt-10 flex justify-center gap-8" style="transition-delay: 0.3s;">
        <!-- ICONOS -->
        <a href="mailto:maciagiovanni4@gmail.com">📧</a>
        <a href="https://www.linkedin.com" target="_blank">💼</a>
        <a href="https://github.com" target="_blank">💻</a>
      </div>
    </section>

  </main>
</Layout>
---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="flex flex-col bg-slate-900 text-white">

    <section id="home" class="min-h-screen flex items-center justify-center pt-20">
      <div class="text-center max-w-3xl mx-4 hero-animate">
        <h1 class="text-4xl md:text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-rose-400 mb-4">
          Giovanni Macia
        </h1>
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">
          Frontend Developer en formación
        </h2>
        <p class="text-slate-300 text-lg mb-8 max-w-2xl mx-auto">
          Construyo interfaces modernas, rápidas y enfocadas en el usuario. Estudiante de Analista de Sistemas con base técnica en lógica y bases de datos.
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <a href="https://www.linkedin.com/in/giovanni-macia-632a2b359" target="_blank" class="bg-[#0077b5] hover:bg-[#005c8d] text-white font-semibold py-3 px-6 rounded-full transition-all hover:scale-105 flex items-center gap-2">
             LinkedIn
          </a>
          <a href="/CV-Giovanni-Macia-Sistemas.pdf" download class="bg-slate-700 hover:bg-slate-600 text-white font-semibold py-3 px-6 rounded-full transition-all hover:scale-105 flex items-center gap-2 border border-slate-500">
             Descargar CV
          </a>
          <a href="https://github.com/GiovanniMacia" target="_blank" class="bg-slate-800 hover:bg-black text-white font-semibold py-3 px-6 rounded-full transition-all hover:scale-105">
             GitHub
          </a>
        </div>
      </div>
    </section>

    <section id="about" class="fade-in py-24 px-6">
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-12 items-center">
        <div class="text-left">
          <h2 class="fade-item text-3xl font-bold mb-6 border-l-4 border-orange-400 pl-4">Sobre mí</h2>
          <p class="fade-item text-slate-300 text-lg mb-4">
            Actualmente estoy enfocado en mejorar mis habilidades en JavaScript y construir proyectos prácticos que simulen entornos reales de trabajo.
          </p>
          <p class="fade-item text-slate-400 mb-6">
            Mi formación académica en el <strong>IES</strong> y la <strong>UTN</strong>, sumada a mi experiencia administrativa en <strong>7B ingeniería</strong>, me permite abordar el desarrollo de software con un pensamiento analítico, racional y una gran capacidad de organización.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-4">
          <div class="fade-item bg-slate-800/50 p-4 rounded-lg border border-slate-700">
            <h4 class="font-bold text-orange-400 mb-1 text-sm uppercase tracking-widest">Educación</h4>
            <p class="text-white font-medium text-sm">Analista de Sistemas - IES (En curso)</p>
          </div>
          <div class="fade-item bg-slate-800/50 p-4 rounded-lg border border-slate-700">
            <h4 class="font-bold text-orange-400 mb-1 text-sm uppercase tracking-widest">Certificaciones UTN</h4>
            <p class="text-white font-medium text-sm">Bases de Datos e Introducción a la Programación</p>
          </div>
        </div>
      </div>
    </section>

    <section id="skills" class="fade-in py-24 px-6 bg-slate-900/50 text-center">
      <div class="max-w-6xl mx-auto">
        <h2 class="fade-item text-3xl font-bold mb-4 text-center">Stack Tecnológico</h2>
        <p class="fade-item text-slate-400 mb-12 text-center">Herramientas que utilizo para construir proyectos profesionales</p>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
          <div class="fade-item bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-orange-400 transition-colors">
            <h3 class="text-orange-400 font-bold mb-4 flex items-center gap-2"><span>💻</span> Frontend</h3>
            <div class="flex flex-wrap gap-2 text-xs font-semibold uppercase">
              <span class="bg-slate-900 px-2 py-1 rounded border border-slate-700">HTML5</span>
              <span class="bg-slate-900 px-2 py-1 rounded border border-slate-700">CSS3</span>
              <span class="bg-slate-900 px-2 py-1 rounded border border-slate-700 text-yellow-400">JavaScript</span>
              <span class="bg-slate-900 px-2 py-1 rounded border border-slate-700">Astro</span>
              <span class="bg-slate-900 px-2 py-1 rounded border border-slate-700 text-cyan-400">Tailwind</span>
            </div>
          </div>
          <div class="fade-item bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-blue-400 transition-colors">
            <h3 class="text-blue-400 font-bold mb-4 flex items-center gap-2"><span>⚙️</span> Backend & Bases</h3>
            <div class="flex flex-wrap gap-2 text-xs font-semibold uppercase">
              <span class="bg-slate-900 px-2 py-1 rounded border border-slate-700">SQL Server</span>
              <span class="bg-slate-900 px-2 py-1 rounded border border-slate-700">Lógica</span>
              <span class="bg-slate-900 px-2 py-1 rounded border border-slate-700">Modelado de Datos</span>
            </div>
          </div>
          <div class="fade-item bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-purple-400 transition-colors">
            <h3 class="text-purple-400 font-bold mb-4 flex items-center gap-2"><span>🛠️</span> Herramientas</h3>
            <div class="flex flex-wrap gap-2 text-xs font-semibold uppercase">
              <span class="bg-slate-900 px-2 py-1 rounded border border-slate-700">Git</span>
              <span class="bg-slate-900 px-2 py-1 rounded border border-slate-700 text-white">GitHub</span>
              <span class="bg-slate-900 px-2 py-1 rounded border border-slate-700 text-green-500">Excel Avanzado</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="projects" class="fade-in py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="fade-item text-3xl md:text-4xl font-bold text-center mb-12">Proyectos Destacados</h2>
        <div class="grid md:grid-cols-2 gap-8">
          
          <div class="fade-item group bg-slate-800 rounded-xl overflow-hidden border border-slate-700 hover:border-orange-400 transition-all hover:-translate-y-2 shadow-lg">
            <div class="h-48 bg-slate-700 flex items-center justify-center p-8">
               <span class="text-slate-500 font-bold text-lg uppercase tracking-tighter italic">Hupes SRL - Gestión Operativa</span>
            </div>
            <div class="p-6">
              <div class="flex justify-between items-start mb-2">
                <h3 class="text-xl font-bold text-white">Sistema de Gestión Web</h3>
                <span class="text-[10px] uppercase bg-orange-500/10 text-orange-400 px-2 py-1 rounded border border-orange-500/20 font-bold">Tesis</span>
              </div>
              <p class="text-slate-400 text-sm mb-4">Sistema integral para asignación de recursos y alquiler de máquinas viales en Pyme. Optimización de procesos operativos reales.</p>
              <div class="flex flex-wrap gap-2 mb-4 text-[10px]">
                <span class="bg-slate-900 px-2 py-1 rounded">JavaScript</span>
                <span class="bg-slate-900 px-2 py-1 rounded">Astro</span>
                <span class="bg-slate-900 px-2 py-1 rounded font-bold">SQL Server</span>
              </div>
            </div>
          </div>

          <div class="fade-item group bg-slate-800 rounded-xl overflow-hidden border border-slate-700 hover:border-cyan-400 transition-all hover:-translate-y-2 shadow-lg">
            <div class="h-48 bg-white/5 flex items-center justify-center p-8">
              <img src="/soltec-logo.png" class="max-h-full object-contain" alt="Soltec Logo" />
            </div>
            <div class="p-6">
              <div class="flex justify-between items-start mb-2">
                <h3 class="text-xl font-bold text-white">Soltec</h3>
                <span class="text-[10px] uppercase bg-cyan-500/10 text-cyan-400 px-2 py-1 rounded border border-cyan-500/20 font-bold">En Desarrollo</span>
              </div>
              <p class="text-slate-400 text-sm mb-4">Proyecto colaborativo para brindar soluciones tecnológicas integrales. Liderando la interfaz web y experiencia de usuario.</p>
              <div class="flex flex-wrap gap-2 text-[10px]">
                <span class="bg-slate-900 px-2 py-1 rounded text-cyan-400">Tailwind CSS</span>
                <span class="bg-slate-900 px-2 py-1 rounded">Branding</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section id="contact" class="fade-in py-24 text-center px-6">
      <h2 class="fade-item text-3xl font-bold mb-4">Disponible para oportunidades y proyectos freelance</h2>
      <p class="fade-item text-slate-400 mb-8">¿Tienes una idea o una propuesta laboral? ¡Hablemos!</p>
      
      <a href="https://wa.me/5493525419426" target="_blank" class="fade-item inline-block px-10 py-4 bg-green-600 hover:bg-green-700 text-white font-bold rounded-full transition-transform hover:scale-105 shadow-xl">
        Enviar WhatsApp
      </a>
      
      <div class="fade-item mt-12 flex justify-center gap-8">
        <a href="mailto:maciagiovanni4@gmail.com" class="text-slate-400 hover:text-orange-400 transition-colors transform hover:scale-110">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        </a>
        <a href="https://www.linkedin.com/in/giovanni-macia-632a2b359" target="_blank" class="text-slate-400 hover:text-[#0077b5] transition-colors transform hover:scale-110">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
      </div>
    </section>

    <footer class="py-10 text-center text-slate-500 text-sm border-t border-slate-800">
      <p>© 2024 Giovanni Macia Godoy | Jesús María, Córdoba</p>
      <p class="mt-2 text-[10px] opacity-40 uppercase tracking-widest font-mono">Desarrollado con Astro & Tailwind CSS</p>
    </footer>

  </main>
</Layout>
---
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/letrag.svg" />
    <title>Giovanni Macia | Frontend Developer</title>
  </head>

  <body class="bg-slate-900 text-white antialiased">
    <slot />

    <script is:inline>
      // Animaciones de entrada (Optimizadas)
      const setupAnimations = () => {
        const elements = document.querySelectorAll('.fade-in, .fade-item');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        }, { threshold: 0.1 });
        elements.forEach(el => observer.observe(el));
      };

      // Lógica para marcar la sección activa (Nav Highlighter)
      const setupNavHighlighter = () => {
        const sections = document.querySelectorAll('section[id]');
        const navLinks = document.querySelectorAll('nav a');

        const navObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const id = entry.target.getAttribute('id');
              navLinks.forEach(link => {
                link.classList.remove('text-orange-400');
                if (link.getAttribute('href') === `#${id}`) {
                  link.classList.add('text-orange-400');
                }
              });
            }
          });
        }, { threshold: 0.4 });

        sections.forEach(section => navObserver.observe(section));
      };

      // Ejecutar funciones
      setupAnimations();
      setupNavHighlighter();
    </script>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  body {
    margin: 0;
    width: 100%;
    overflow-x: hidden; /* Evita scrolls horizontales raros en móvil */
  }
</style>
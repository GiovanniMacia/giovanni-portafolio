---
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg" />
    <title>Giovanni Macia | Frontend Developer</title>
  </head>

  <body class="bg-slate-900 text-white">

    <nav class="flex justify-center gap-8 p-6 bg-slate-900/70 backdrop-blur-md sticky top-0 z-50 border-b border-slate-800 text-sm font-medium">
      <a href="#home" class="text-slate-300 hover:text-orange-400 transition">Inicio</a>
      <a href="#about" class="text-slate-300 hover:text-orange-400 transition">Sobre mí</a>
      <a href="#skills" class="text-slate-300 hover:text-orange-400 transition">Tecnologías</a>
      <a href="#projects" class="text-slate-300 hover:text-orange-400 transition">Proyectos</a>
      <a href="#contact" class="text-slate-300 hover:text-orange-400 transition">Contacto</a>
    </nav>

    <slot />
	<script>
 	 	const elements = document.querySelectorAll('.fade-in');

  		const observer = new IntersectionObserver((entries) => {
    	entries.forEach(entry => {
      	if (entry.isIntersecting) {
        entry.target.classList.add('visible');
    	  }
    	});
  		});

  		elements.forEach(el => observer.observe(el));
	</script>

  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    width: 100%;
  }
</style>